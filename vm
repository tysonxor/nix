#!/usr/bin/env bash
# vm — manage Lima dev guests
set -euo pipefail

REPO="$HOME/nix"
TEMPLATE="$REPO/lima/guest.yaml"
SCRIPT_URL="https://raw.githubusercontent.com/tysonxor/nix/main/bootstrap-guest.sh"
KEYDIR="$HOME/.config/nix-secrets"   # per-VM age PRIVATE keys — NEVER in the repo

cmd="${1:-help}"
name="${2:-}"

need_name() { [ -n "$name" ] || { echo "usage: vm $cmd <name>"; exit 1; }; }

case "$cmd" in
  new)
    # Scaffold a whole identity: age keypair + .sops.yaml rule + encrypted
    # secrets.yaml + vm-configs/<name>.nix template. Explicit — does NOT commit/push.
    need_name
    [ -e "$REPO/vm-configs/$name.nix" ] && { echo "ERROR: vm-configs/$name.nix already exists."; exit 1; }
    for bin in age-keygen sops yq ssh-keygen; do
      command -v "$bin" >/dev/null || { echo "ERROR: '$bin' not on PATH (git add home.nix && vm rebuild)."; exit 1; }
    done

    # 1. age keypair (Mac keystore, outside the repo)
    mkdir -p "$KEYDIR"; chmod 700 "$KEYDIR"
    KEYFILE="$KEYDIR/$name.age"
    if [ -f "$KEYFILE" ]; then
      echo "==> Reusing existing key $KEYFILE"
    else
      age-keygen -o "$KEYFILE" >/dev/null 2>&1; chmod 600 "$KEYFILE"
      echo "==> Generated age key $KEYFILE"
    fi
    PUB=$(age-keygen -y "$KEYFILE")

    # 2. append an anchored creation_rule -> only this VM's key
    RE="^vm-configs/${name}/secrets\\.yaml\$" PUB="$PUB" \
      yq -i '.creation_rules += [{"path_regex": strenv(RE), "age": strenv(PUB)}]' "$REPO/.sops.yaml"
    echo "==> Added .sops.yaml rule for $name"

    # 3. generate this VM's GitHub SSH keypair, store the PRIVATE key, encrypt.
    #    Every guest needs a GitHub key, so make it up front instead of seeding a
    #    REPLACE_ME placeholder. Add your own later with 'vm secrets' if you must.
    mkdir -p "$REPO/vm-configs/$name"
    TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
    ssh-keygen -t ed25519 -C "$name" -f "$TMP/id_ed25519" -N "" >/dev/null
    PUBKEY=$(cat "$TMP/id_ed25519.pub")
    # $(...) strips trailing newlines, but an OpenSSH key MUST end in one — keep it.
    KEY="$(cat "$TMP/id_ed25519"; echo x)"; KEY="${KEY%x}"
    KEY="$KEY" yq -n '.ssh_key = strenv(KEY)' > "$REPO/vm-configs/$name/secrets.yaml"
    ( cd "$REPO" && sops -e -i "vm-configs/$name/secrets.yaml" )
    echo "==> Generated GitHub SSH keypair + encrypted vm-configs/$name/secrets.yaml"

    # 4. vm-configs/<name>.nix from template
    cat > "$REPO/vm-configs/$name.nix" <<EOF
{ config, pkgs, ... }:
{
  imports = [ ../guests.nix ];

  programs.git.settings = {
    user.name = "TODO-set-me";
    user.email = "TODO@example.com";
  };

  programs.ssh = {
    enable = true;
    enableDefaultConfig = false;
    settings."github.com".identityFile = "~/.ssh/id_ed25519";
  };

  # Secrets for this VM (edit with: vm secrets $name). Add only what this
  # guest needs — snowflake per guest.
  sops.defaultSopsFile = ./$name/secrets.yaml;
  sops.secrets."ssh_key" = { path = "/home/tyson.guest/.ssh/id_ed25519"; mode = "0600"; };
  # sops.secrets."aws_config" = { path = "/home/tyson.guest/.aws/config"; };
  # sops.secrets."env_local"  = { path = "/home/tyson.guest/.config/$name/env.local"; };
}
EOF
    echo "==> Wrote vm-configs/$name.nix"
    cat <<EOF

Next:
  1. edit git identity in vm-configs/$name.nix
  2. add this VM's public key at https://github.com/settings/keys :
       $PUBKEY
  3. git add -A && git commit && git push
  4. vm create $name

  (add more secrets: vm secrets $name  •  regenerate the GitHub key: vm genkey $name)
EOF
    ;;

  secrets)
    # Edit/rotate this VM's secrets in place (sops decrypts for edit, re-encrypts on save).
    need_name
    [ -f "$REPO/vm-configs/$name/secrets.yaml" ] || { echo "ERROR: no secrets for '$name'. Run: vm new $name"; exit 1; }
    command -v sops >/dev/null || { echo "ERROR: 'sops' not on PATH (git add home.nix && vm rebuild)."; exit 1; }
    ( cd "$REPO" && SOPS_AGE_KEY_FILE="$KEYDIR/$name.age" sops "vm-configs/$name/secrets.yaml" )
    ;;

  genkey)
    # Generate a fresh ed25519 SSH keypair for this VM: store the PRIVATE key in
    # its sops secrets (ssh_key -> ~/.ssh/id_ed25519 in the guest) and print the
    # PUBLIC key to register on GitHub. Saves hand-generating + pasting a key.
    need_name
    SECRETS="$REPO/vm-configs/$name/secrets.yaml"
    KEYFILE="$KEYDIR/$name.age"
    [ -f "$SECRETS" ] || { echo "ERROR: no secrets for '$name'. Run: vm new $name"; exit 1; }
    [ -f "$KEYFILE" ] || { echo "ERROR: no age key for '$name' at $KEYFILE."; exit 1; }
    for bin in ssh-keygen sops yq; do
      command -v "$bin" >/dev/null || { echo "ERROR: '$bin' not on PATH (git add home.nix && vm rebuild)."; exit 1; }
    done
    # Don't silently clobber a key that's already been filled in.
    CUR=$(SOPS_AGE_KEY_FILE="$KEYFILE" sops -d --extract '["ssh_key"]' "$SECRETS" 2>/dev/null || true)
    if [ -n "$CUR" ] && [ "$CUR" != "REPLACE_ME" ]; then
      read -r -p "ssh_key is already set for '$name'. Replace it with a fresh keypair? [y/N] " ans
      [ "$ans" = "y" ] || [ "$ans" = "Y" ] || { echo "aborted."; exit 1; }
    fi
    TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
    ssh-keygen -t ed25519 -C "$name" -f "$TMP/id_ed25519" -N "" >/dev/null
    # $(...) strips trailing newlines, but an OpenSSH key MUST end in one — keep it.
    KEY="$(cat "$TMP/id_ed25519"; echo x)"; KEY="${KEY%x}"
    # decrypt -> set the multiline key with yq -> re-encrypt (recipient from .sops.yaml)
    ( cd "$REPO"
      SOPS_AGE_KEY_FILE="$KEYFILE" sops -d -i "vm-configs/$name/secrets.yaml"
      KEY="$KEY" yq -i '.ssh_key = strenv(KEY)' "vm-configs/$name/secrets.yaml"
      sops -e -i "vm-configs/$name/secrets.yaml" )
    echo "==> Stored a fresh ed25519 private key in vm-configs/$name/secrets.yaml"
    echo ""
    echo "  Public key — add at https://github.com/settings/keys :"
    echo "  ----------------------------------------"
    cat "$TMP/id_ed25519.pub"
    echo "  ----------------------------------------"
    ;;

  rekey)
    # Rotate this VM's age key and re-encrypt its secrets to the new key.
    need_name
    OLD="$KEYDIR/$name.age"
    [ -f "$OLD" ] || { echo "ERROR: no key for '$name' at $OLD"; exit 1; }
    [ -f "$REPO/vm-configs/$name/secrets.yaml" ] || { echo "ERROR: no secrets for '$name'."; exit 1; }
    for bin in age-keygen sops yq; do
      command -v "$bin" >/dev/null || { echo "ERROR: '$bin' not on PATH (git add home.nix && vm rebuild)."; exit 1; }
    done
    # NB: age-keygen -o refuses to overwrite the file mktemp already created,
    # so write via stdout redirect instead.
    NEW=$(mktemp); age-keygen > "$NEW" 2>/dev/null; chmod 600 "$NEW"
    PUB=$(age-keygen -y "$NEW")
    RE="^vm-configs/${name}/secrets\\.yaml\$" PUB="$PUB" \
      yq -i '(.creation_rules[] | select(.path_regex == strenv(RE)) | .age) = strenv(PUB)' "$REPO/.sops.yaml"
    # updatekeys decrypts with the OLD key, re-encrypts to the NEW recipient
    ( cd "$REPO" && SOPS_AGE_KEY_FILE="$OLD" sops updatekeys -y "vm-configs/$name/secrets.yaml" )
    mv "$NEW" "$OLD"; chmod 600 "$OLD"
    echo "==> Rekeyed $name. commit+push, then RECREATE the VM (vm destroy $name && vm create $name)"
    echo "    so the guest receives the new key."
    ;;

  create)
    need_name
    [ -f "$REPO/vm-configs/$name.nix" ] || { echo "ERROR: create vm-configs/$name.nix first (vm new $name), then push."; exit 1; }
    SECRETS="$REPO/vm-configs/$name/secrets.yaml"
    KEYFILE="$KEYDIR/$name.age"
    # Pre-flight (explicit, fail loud BEFORE booting): a sops VM needs its key.
    if [ -f "$SECRETS" ] && [ ! -f "$KEYFILE" ]; then
      echo "ERROR: vm-configs/$name/secrets.yaml exists but no age key at $KEYFILE."
      echo "       Restore the key from your backup, or run: vm new $name"
      exit 1
    fi
    limactl start --name="$name" "$TEMPLATE" --tty=false
    # --- sops-nix: place this VM's age PRIVATE key BEFORE home-manager runs ---
    # mounts:[] seals the guest, so copy the key in over Lima's SSH.
    if [ -f "$KEYFILE" ]; then
      echo "==> Injecting age key for '$name'..."
      limactl shell "$name" mkdir -p /home/tyson.guest/.config/sops/age
      limactl copy "$KEYFILE" "$name:/home/tyson.guest/.config/sops/age/keys.txt"
      limactl shell "$name" chmod 600 /home/tyson.guest/.config/sops/age/keys.txt
    else
      echo "==> No age key for '$name' — guest declares no sops secrets. Continuing."
    fi
    limactl shell "$name" bash -c "curl -fsSL $SCRIPT_URL | bash -s -- $name"
    ;;
  destroy)
    need_name
    limactl stop "$name" && limactl delete "$name"
    ;;
  destroy-secrets)
    # Permanently remove an identity's config + decryption key + .sops.yaml rule.
    # (Run 'vm destroy <name>' first if the VM still exists.)
    need_name
    command -v yq >/dev/null || { echo "ERROR: 'yq' not on PATH (git add home.nix && vm rebuild)."; exit 1; }
    echo "This will PERMANENTLY delete:"
    echo "  - $REPO/vm-configs/$name.nix"
    echo "  - $REPO/vm-configs/$name/  (encrypted secrets)"
    echo "  - $KEYDIR/$name.age        (age PRIVATE key — unrecoverable)"
    echo "  - the '$name' rule in $REPO/.sops.yaml"
    read -r -p "Delete secrets + config for '$name'? [y/N] " ans
    [ "$ans" = "y" ] || [ "$ans" = "Y" ] || { echo "aborted."; exit 1; }
    rm -rf "$REPO/vm-configs/$name" "$REPO/vm-configs/$name.nix"
    rm -f "$KEYDIR/$name.age"
    RE="^vm-configs/${name}/secrets\\.yaml\$" \
      yq -i 'del(.creation_rules[] | select(.path_regex == strenv(RE)))' "$REPO/.sops.yaml"
    echo "==> Removed secrets + config for '$name'. Commit + push to finish."
    ;;
  shell)
    need_name
    limactl shell "$name" /home/tyson.guest/.nix-profile/bin/zsh
    ;;
  rebuild)
    sudo darwin-rebuild switch --flake "$REPO#mac"
    ;;
  list)
    limactl list
    ;;
  *)
    cat <<EOF
vm — manage dev guests

  vm new <name>       scaffold a new identity (age key + .sops.yaml + GitHub SSH key + vm-configs/<name>.nix)
  vm secrets <name>   edit/rotate this VM's sops secrets
  vm genkey <name>    generate a fresh GitHub SSH keypair for this VM (prints the public key)
  vm rekey <name>     rotate this VM's age key + re-encrypt its secrets
  vm create <name>    create + bootstrap a guest
  vm destroy <name>   stop + delete a guest
  vm destroy-secrets <name>   remove an identity's config + age key + .sops.yaml rule
  vm shell <name>     shell into a guest
  vm list             list guests
  vm rebuild          rebuild the Mac host config
EOF
    ;;
esac
